<%- include("partials/header", { title }) %>

<section class="card">
  <div class="view-switch-row">
    <h2>统计视角</h2>
    <form method="GET" action="/" class="view-switch-form">
      <select name="view" id="overviewViewSelect">
        <option value="family" <%= viewMode === "family" ? "selected" : "" %>>家庭</option>
        <option value="member" <%= viewMode === "member" ? "selected" : "" %>>个人</option>
      </select>
      <select name="member_id" id="overviewMemberSelect" <%= viewMode === "member" ? "" : "disabled" %>>
        <% members.forEach((member) => { %>
          <option value="<%= member.id %>" <%= selectedMemberId === member.id ? "selected" : "" %>><%= member.name %></option>
        <% }) %>
      </select>
      <button type="submit">应用</button>
    </form>
  </div>
</section>

<section class="card">
  <% if (setupRequired) { %>
    <h2>请先完成配置</h2>
    <p>先配置家庭成员和资产分类科目，再开始录入每月数据。</p>
    <a href="/setup">去配置</a>
  <% } else if (!latest || !stats) { %>
    <h2>暂无数据</h2>
    <p>先去录入页添加本月资产数据。</p>
  <% } else { %>
    <h2><%= latest.period_date.toISOString().slice(0, 10) %> 总览</h2>
    <div class="kpis">
      <div class="kpi">
        <span>家庭净资产</span>
        <strong>¥ <%= stats.householdNetAssets.toLocaleString("zh-CN") %></strong>
      </div>
      <div class="kpi">
        <span>本期变化</span>
        <strong class="<%= stats.periodChange >= 0 ? 'up' : 'down' %>">
          ¥ <%= stats.periodChange.toLocaleString("zh-CN") %>
        </strong>
      </div>
      <div class="kpi">
        <span>总资产</span>
        <strong>¥ <%= stats.totalAssets.toLocaleString("zh-CN") %></strong>
      </div>
      <div class="kpi">
        <span>总负债</span>
        <strong>¥ <%= stats.totalLiabilities.toLocaleString("zh-CN") %></strong>
      </div>
      <div class="kpi">
        <span>本期收入</span>
        <strong>¥ <%= stats.totalIncome.toLocaleString("zh-CN") %></strong>
      </div>
      <div class="kpi">
        <span>本期股票盈亏</span>
        <strong class="<%= stats.stockPnlManual >= 0 ? 'up' : 'down' %>">¥ <%= stats.stockPnlManual.toLocaleString("zh-CN") %></strong>
      </div>
      <div class="kpi">
        <span>已记录支出 <button type="button" class="help-tip" data-tip="你在支出类科目中手动录入的金额，用于和推算支出做对比。" aria-label="已记录支出口径说明">?</button></span>
        <strong>¥ <%= stats.totalExpenseManual.toLocaleString("zh-CN") %></strong>
      </div>
      <div class="kpi">
        <span>推算总支出 <button type="button" class="help-tip" data-tip="估算值。公式：本期收入 + 本期投资收益 - 本期净资产变化。需至少两期快照，且资产负债、收入和投资收益录入口径一致。" aria-label="推算总支出口径说明">?</button></span>
        <% if (stats.totalExpense === null) { %>
          <strong class="muted">需要至少两期数据</strong>
        <% } else { %>
          <strong>¥ <%= stats.totalExpense.toLocaleString("zh-CN") %></strong>
        <% } %>
      </div>
      <div class="kpi">
        <span>隐含支出估算 <button type="button" class="help-tip" data-tip="估算值。公式：推算总支出 - 已记录支出。它用于提示可能未记录或口径不一致的支出，不等同于真实流水。" aria-label="隐含支出估算说明">?</button></span>
        <% if (stats.implicitExpense === null) { %>
          <strong class="muted">-</strong>
        <% } else { %>
          <strong class="<%= stats.implicitExpense >= 0 ? 'down' : 'up' %>">¥ <%= stats.implicitExpense.toLocaleString("zh-CN") %></strong>
        <% } %>
      </div>
    </div>
    <p class="derived-metric-note">推算指标依赖连续快照和一致录入口径，适合用于月度复盘和异常排查，不应视为逐笔支出流水。</p>
  <% } %>
</section>

<section class="card">
  <h2>成员结构</h2>
  <% if (!memberTotals || !memberTotals.length) { %>
    <p>暂无成员数据。</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>成员</th>
          <th>收入</th>
          <th>资产</th>
          <th>负债</th>
          <th>净资产</th>
        </tr>
      </thead>
      <tbody>
        <% memberTotals.forEach((row) => { %>
          <tr>
            <td><%= row.member %></td>
            <td>¥ <%= row.totalIncome.toLocaleString("zh-CN") %></td>
            <td>¥ <%= row.totalAssets.toLocaleString("zh-CN") %></td>
            <td>¥ <%= row.totalLiabilities.toLocaleString("zh-CN") %></td>
            <td>¥ <%= row.netAssets.toLocaleString("zh-CN") %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</section>

<script>
  (() => {
    const viewSelect = document.getElementById("overviewViewSelect");
    const memberSelect = document.getElementById("overviewMemberSelect");
    if (!viewSelect || !memberSelect) return;
    const refreshMemberState = () => {
      memberSelect.disabled = viewSelect.value !== "member";
    };
    viewSelect.addEventListener("change", refreshMemberState);
    refreshMemberState();
  })();
</script>

<%- include("partials/footer") %>
