<%- include("partials/header", { title }) %>

<section class="card">
  <div class="section-header">
    <div>
      <h2>用户管理</h2>
      <p class="muted">只有管理员可以创建新用户。新用户会拥有独立的家庭资产空间。</p>
    </div>
  </div>

  <% if (message) { %>
    <p class="success"><%= message %></p>
  <% } %>
  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <form method="POST" action="/admin/users" class="form-grid">
    <label>用户邮箱
      <input name="email" type="email" value="<%= email || '' %>" required autocomplete="username" />
    </label>
    <label>初始密码
      <input name="password" type="password" required minlength="8" autocomplete="new-password" />
    </label>
    <label>确认密码
      <input name="password_confirm" type="password" required minlength="8" autocomplete="new-password" />
    </label>
    <button type="submit">创建用户</button>
  </form>
</section>

<section class="card">
  <h2>已有用户</h2>
  <table>
    <thead>
      <tr>
        <th>邮箱</th>
        <th>角色</th>
        <th>创建时间</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach((user) => { %>
        <tr>
          <td><%= user.email %></td>
          <td><%= user.is_admin ? "管理员" : "普通用户" %></td>
          <td><%= user.created_at ? user.created_at.toISOString().slice(0, 10) : "-" %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include("partials/footer") %>
