<%- include("partials/header", { title }) %>

<section class="card">
  <h2>月度录入</h2>
  <p class="muted">以下字段来自 Setup 配置。股票口径：手工输入“股票盈亏（stock_pnl）”，系统自动反推净投入。</p>
  <form method="POST" action="/entry" class="form-grid">
    <label>统计日期
      <input name="period_date" type="date" value="<%= defaultDate %>" required />
    </label>
    <label>本期备注
      <input name="note" type="text" placeholder="例如：年终奖到账" />
    </label>

    <% config.members.forEach((member) => { %>
      <fieldset>
        <legend><%= member.name %></legend>
        <% const memberItems = config.items.filter((item) => item.owner_member_id === member.id); %>
        <% memberItems.forEach((item) => { %>
          <label>
            <%= item.name %> <span class="muted">(<%= item.kind %>)</span>
            <input name="item_<%= item.id %>" type="number" step="0.01" value="0" />
          </label>
        <% }) %>
      </fieldset>
    <% }) %>

    <fieldset>
      <legend>共同</legend>
      <% const commonItems = config.items.filter((item) => !item.owner_member_id); %>
      <% commonItems.forEach((item) => { %>
        <label>
          <%= item.name %> <span class="muted">(<%= item.kind %>)</span>
          <input name="item_<%= item.id %>" type="number" step="0.01" value="0" />
        </label>
      <% }) %>
    </fieldset>

    <button type="submit">保存并查看趋势</button>
  </form>
</section>

<section class="card">
  <h2>已记录周期</h2>
  <% if (!periods.length) { %>
    <p>暂无记录。</p>
  <% } else { %>
    <ul class="period-list">
      <% periods.forEach((period) => { %>
        <li>
          <strong><%= period.period_date.toISOString().slice(0, 10) %></strong>
          <span><%= period.note || "无备注" %></span>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include("partials/footer") %>
