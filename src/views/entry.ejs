<%- include("partials/header", { title }) %>

<section class="card">
  <div class="section-header">
    <div>
      <h2>月度录入</h2>
      <% if (selectedPeriod && !isCopyMode) { %>
        <p class="muted">正在编辑 <%= selectedPeriod.period_date.toISOString().slice(0, 10) %> 的历史快照。</p>
      <% } else if (isCopyMode) { %>
        <p class="muted">已复制 <%= selectedPeriod.period_date.toISOString().slice(0, 10) %> 的历史快照数据，请确认统计日期、本期投资收益和金额后保存为新一期。</p>
      <% } else { %>
        <p class="muted">录入本期各科目余额。缺少科目时，可在本页快速新增。</p>
      <% } %>
    </div>
    <a href="/setup" class="btn-ghost">进入配置</a>
  </div>

  <% if (errors && errors.length) { %>
    <div class="alert error">
      <% errors.forEach((error) => { %>
        <p><%= error %></p>
      <% }) %>
    </div>
  <% } %>

  <details class="add-item-panel compact-panel">
    <summary>新增科目</summary>
    <form method="POST" action="/setup/items" class="form-grid" id="entryQuickItemForm">
      <input type="hidden" name="return_to" value="/entry" />
      <label>科目名称
        <input name="item_name" type="text" placeholder="例如：建设银行、车贷、工资收入" required autocomplete="off" />
      </label>
      <label>科目类型
        <select name="kind" id="entryQuickKindSelect" required>
          <option value="asset">资产</option>
          <option value="liability">负债</option>
          <option value="income">收入</option>
          <option value="expense">支出</option>
        </select>
      </label>
      <label id="entryQuickAssetGroupField">资产子类
        <select name="asset_group">
          <option value="cash">现金/存款</option>
          <option value="investment">投资</option>
          <option value="housing_fund">公积金类</option>
          <option value="other">其他资产</option>
        </select>
      </label>
      <label>归属成员
        <select name="owner_member_id">
          <option value="">共同</option>
          <% config.members.forEach((member) => { %>
            <option value="<%= member.id %>"><%= member.name %></option>
          <% }) %>
        </select>
      </label>
      <button type="submit">添加并返回录入</button>
    </form>
  </details>

  <form method="POST" action="/entry" class="form-grid" id="entryForm">
    <label>统计日期
      <input name="period_date" type="date" value="<%= defaultDate %>" required />
    </label>
    <label>本期备注
      <input name="note" type="text" placeholder="例如：年终奖到账" value="<%= entryNote || '' %>" />
    </label>
    <label>本期投资收益 <button type="button" class="help-tip" data-tip="填写本期投资组合盈亏，用于计算推算总支出、隐含支出估算和投资净投入估算。若本期没有复核投资盈亏，可先填 0，但趋势提示可能提醒你复核。" aria-label="本期投资收益说明">?</button>
      <input name="stock_pnl_manual" class="amount-input" type="number" inputmode="decimal" step="0.01" value="<%= stockPnlManual || 0 %>" />
    </label>

    <% const entryKindGroups = [
      { key: "asset", label: "资产" },
      { key: "liability", label: "负债" },
      { key: "income", label: "收入" },
      { key: "expense", label: "支出" },
    ]; %>
    <% config.members.forEach((member, memberIndex) => { %>
      <% const memberItems = config.items.filter((item) => item.owner_member_id === member.id); %>
      <details class="entry-group" <%= memberIndex === 0 ? "open" : "" %>>
        <summary>
          <span><%= member.name %></span>
          <small><%= memberItems.length %> 个科目</small>
        </summary>
        <div class="entry-group-body">
          <% entryKindGroups.forEach((group) => { %>
            <% const groupedItems = memberItems.filter((item) => item.kind === group.key); %>
            <% if (groupedItems.length) { %>
              <div class="entry-kind-section">
                <h3><%= group.label %></h3>
                <div class="entry-field-grid">
                  <% groupedItems.forEach((item) => { %>
                    <label>
                      <%= item.name %> <span class="kind-chip"><%= group.label %></span>
                      <% if (!item.is_active) { %><span class="badge-off">已停用</span><% } %>
                      <input name="item_<%= item.id %>" class="amount-input" type="number" inputmode="decimal" step="0.01" value="<%= entryValues[item.id] ?? 0 %>" />
                    </label>
                  <% }) %>
                </div>
              </div>
            <% } %>
          <% }) %>
        </div>
      </details>
    <% }) %>

    <% const commonItems = config.items.filter((item) => !item.owner_member_id); %>
    <details class="entry-group" <%= config.members.length === 0 ? "open" : "" %>>
      <summary>
        <span>共同</span>
        <small><%= commonItems.length %> 个科目，不自动分摊到个人视角</small>
      </summary>
      <div class="entry-group-body">
        <% entryKindGroups.forEach((group) => { %>
          <% const groupedItems = commonItems.filter((item) => item.kind === group.key); %>
          <% if (groupedItems.length) { %>
            <div class="entry-kind-section">
              <h3><%= group.label %></h3>
              <div class="entry-field-grid">
                <% groupedItems.forEach((item) => { %>
                  <label>
                    <%= item.name %> <span class="kind-chip"><%= group.label %></span>
                    <% if (!item.is_active) { %><span class="badge-off">已停用</span><% } %>
                    <input name="item_<%= item.id %>" class="amount-input" type="number" inputmode="decimal" step="0.01" value="<%= entryValues[item.id] ?? 0 %>" />
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
    </details>

    <div class="save-bar entry-save-bar">
      <div>
        <strong id="entryChangeSummary">尚未修改</strong>
        <span class="muted" id="entryDraftStatus" role="status" aria-live="polite"></span>
      </div>
      <div class="actions">
        <button type="submit"><%= selectedPeriod && !isCopyMode ? "保存历史快照" : "保存并查看趋势" %></button>
        <button type="button" class="btn-ghost" id="clearEntryDraftBtn">清除草稿</button>
      </div>
    </div>
  </form>
</section>

<script>
  window.__ENTRY_SHOULD_RESTORE_DRAFT__ = <%= !selectedPeriod && !isCopyMode && !(errors && errors.length) ? "true" : "false" %>;
  (() => {
    const kindSelect = document.getElementById("entryQuickKindSelect");
    const assetGroupField = document.getElementById("entryQuickAssetGroupField");
    if (!kindSelect || !assetGroupField) return;
    const refresh = () => {
      assetGroupField.style.display = kindSelect.value === "asset" ? "grid" : "none";
    };
    kindSelect.addEventListener("change", refresh);
    refresh();
  })();
</script>
<script src="/entry.js"></script>

<section class="card">
  <h2>已记录周期</h2>
  <% if (!periods.length) { %>
    <p>暂无记录。</p>
  <% } else { %>
    <ul class="period-list">
      <% periods.forEach((period) => { %>
        <li>
          <div>
            <strong><%= period.period_date.toISOString().slice(0, 10) %></strong>
            <span><%= period.note || "无备注" %></span>
          </div>
          <div class="actions">
            <a href="/entry?period_id=<%= period.id %>" class="btn-ghost">查看/编辑</a>
            <a href="/entry?copy_from=<%= period.id %>" class="btn-ghost">复制</a>
            <form
              method="POST"
              action="/entry/periods/<%= period.id %>/delete"
              class="inline-delete-form"
              data-period-date="<%= period.period_date.toISOString().slice(0, 10) %>"
              data-period-note="<%= period.note || '无备注' %>"
            >
              <button type="submit" class="btn-ghost danger">删除</button>
            </form>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include("partials/footer") %>
