<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> - 家庭资产</title>
    <link rel="stylesheet" href="/styles.css" />
    <script src="/vendor/chart.js"></script>
  </head>
  <body>
    <header class="topbar">
      <h1>家庭资产更新</h1>
      <nav>
        <a href="/setup">配置</a>
        <a href="/">总览</a>
        <a href="/entry">录入</a>
        <a href="/trends">趋势</a>
        <a href="/backup">备份</a>
        <% if (authEnabled) { %>
          <form method="POST" action="/logout" class="nav-form">
            <button type="submit" class="nav-button">退出</button>
          </form>
        <% } %>
      </nav>
    </header>
    <section class="flow-wrap">
      <div class="flow">
        <% const onSetup = currentPath.startsWith("/setup"); %>
        <% const onEntry = currentPath.startsWith("/entry"); %>
        <% const onTrends = currentPath.startsWith("/trends"); %>
        <% const setupDone = onEntry || onTrends; %>
        <% const entryDone = onTrends; %>
        <div class="flow-step <%= onSetup ? 'active' : setupDone ? 'done' : '' %>">
          <span class="dot">1</span>
          <span>配置</span>
        </div>
        <div class="flow-line <%= setupDone ? 'done' : '' %>"></div>
        <div class="flow-step <%= onEntry ? 'active' : entryDone ? 'done' : '' %>">
          <span class="dot">2</span>
          <span>录入</span>
        </div>
        <div class="flow-line <%= entryDone ? 'done' : '' %>"></div>
        <div class="flow-step <%= onTrends ? 'active' : '' %>">
          <span class="dot">3</span>
          <span>趋势</span>
        </div>
      </div>
    </section>
    <main class="container">
