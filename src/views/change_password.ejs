<%- include("partials/header", { title }) %>

<section class="card auth-card">
  <h2>修改密码</h2>
  <p class="muted">修改后请使用新密码登录。当前会话会继续保持有效。</p>

  <% if (message) { %>
    <p class="success"><%= message %></p>
  <% } %>
  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <form method="POST" action="/account/password" class="form-grid">
    <label>当前密码
      <input name="current_password" type="password" required autocomplete="current-password" />
    </label>
    <label>新密码
      <input name="new_password" type="password" required minlength="8" autocomplete="new-password" />
    </label>
    <label>确认新密码
      <input name="password_confirm" type="password" required minlength="8" autocomplete="new-password" />
    </label>
    <button type="submit">更新密码</button>
  </form>
</section>

<%- include("partials/footer") %>
