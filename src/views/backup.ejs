<%- include("partials/header", { title }) %>

<section class="card">
  <div class="section-header">
    <div>
      <h2>数据导出与备份</h2>
      <p class="muted">定期导出备份，避免部署、迁移或误操作造成家庭资产数据丢失。</p>
    </div>
  </div>
  <div class="actions">
    <a href="/backup/export.json" class="btn-primary-link">下载完整 JSON 备份</a>
    <a href="/backup/export.csv" class="btn-ghost">下载快照 CSV</a>
  </div>
</section>

<section class="card">
  <h2>导入恢复</h2>
  <p class="muted">粘贴此前下载的完整 JSON 备份。导入会覆盖当前成员、科目和快照数据，请先确认已经保留当前备份。</p>
  <% if (message) { %>
    <p class="status success"><%= message %></p>
  <% } %>
  <% if (error) { %>
    <p class="status error"><%= error %></p>
  <% } %>
  <form method="POST" action="/backup/import" class="form-grid" id="backupImportForm">
    <label>JSON 备份内容
      <textarea name="backup_json" rows="12" placeholder="粘贴完整 JSON 备份内容" required></textarea>
    </label>
    <label class="inline-checkbox">
      <input type="checkbox" id="confirmImport" required />
      我确认导入会覆盖当前数据，并已按需下载当前备份
    </label>
    <button type="submit">导入并恢复</button>
  </form>
</section>

<script>
  (() => {
    const form = document.getElementById("backupImportForm");
    const textarea = form?.querySelector("textarea[name='backup_json']");
    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      let parsed;
      try {
        parsed = JSON.parse(textarea?.value || "");
      } catch (_err) {
        alert("备份 JSON 无法解析，请检查内容是否完整。");
        return;
      }
      const periods = Array.isArray(parsed.snapshotPeriods) ? parsed.snapshotPeriods : [];
      const dates = periods.map((period) => period.period_date).filter(Boolean).sort();
      const ok = await window.confirmDanger({
        title: "导入覆盖当前数据",
        message: "导入会覆盖当前成员、科目、历史快照和明细数据。",
        details: [
          `将导入成员 ${Array.isArray(parsed.members) ? parsed.members.length : 0} 位。`,
          `将导入科目 ${Array.isArray(parsed.trackingItems) ? parsed.trackingItems.length : 0} 个。`,
          `将导入快照 ${periods.length} 期${dates.length ? `，范围 ${dates[0]} 至 ${dates[dates.length - 1]}` : ""}。`,
          "导入前请确认已经下载当前完整 JSON 备份。",
        ],
        confirmText: "确认导入并覆盖",
      });
      if (ok) form.submit();
    });
  })();
</script>

<%- include("partials/footer") %>
